# ARC-AGI-3 Genetic Baby V6.3 - Configuration
# Copie este arquivo para .env e ajuste os valores

# API e Autenticação
ARC_API_KEY=
ONLINE_MODE=false

# Validação
VALIDATION_EPISODES=10
VALIDATION_TIMEOUT=300
VALIDATION_EXTRA_ARGS=

# Dashboard
DASHBOARD_PORT=8080
DASHBOARD_WEB_PORT=8081
DASHBOARD_REFRESH=10

# Build
BUILD_VERSION=v6.3-complete

# Testes
PYTEST_ARGS=-v --tb=short
TEST_COVERAGE=true

# Ambiente
LOG_LEVEL=INFO
RESTART_POLICY=no
ENVIRONMENT=development

# Recursos
DOCKER_MEMORY_LIMIT=4G
DOCKER_CPU_LIMIT='2'
